# GitHub OAuth App (create at github.com/settings/developers)
# Set callback URL to: https://your-app.vercel.app/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Auth.js secret — run: openssl rand -base64 32
AUTH_SECRET=

# Token encryption — run: openssl rand -base64 32
TOKEN_ENCRYPTION_SECRET=

# Neon Postgres — auto-filled by Vercel Marketplace, or paste your Neon URL
DATABASE_URL=

# App URL (Auth.js v5 uses AUTH_URL, not NEXTAUTH_URL)
AUTH_URL=https://your-app.vercel.app
